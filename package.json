{
  "name": "the-furnace",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous coding agent system orchestrated via Temporal workflows.",
  "scripts": {
    "dev": "npm run --prefix server dev",
    "build:devcontainer": "tsx --env-file=.env scripts/build-devcontainer-image.ts",
    "build:worker": "tsx --env-file=.env scripts/build-worker.ts",
    "test": "npm run --prefix server test && npm run test:devcontainer",
    "test:devcontainer": "npm run --prefix server test -- --root .. tests/devcontainer-image-build.test.ts",
    "test:devcontainer:e2e": "tsx scripts/test-devcontainer-image-e2e.ts",
    "test:container-as-worker:e2e": "npm run --prefix server test:container-as-worker:e2e"
  },
  "devDependencies": {
    "@devcontainers/cli": "0.85.0",
    "@types/node": "^22.0.0",
    "jsonc-parser": "3.3.1",
    "tsx": "4.21.0",
    "typescript": "^5.7.0"
  }
}
